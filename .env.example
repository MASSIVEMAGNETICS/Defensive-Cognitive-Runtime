# PROTECTOR_STACK Environment Configuration
# Copy this file to .env and adjust values for your deployment

# ── Core Runtime ────────────────────────────────────────────────────────────
PROTECTOR_ENV=production          # development | staging | production
PROTECTOR_LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
PROTECTOR_DB_PATH=./protector_data/protector.db
PROTECTOR_DATA_DIR=./protector_data
PROTECTOR_CONFIG_PATH=./config/default_config.yaml

# ── Resource Limits (low-resource mode for Intel i5 / 16 GB RAM) ────────────
PROTECTOR_LOW_RESOURCE_MODE=false
PROTECTOR_MAX_WORKER_THREADS=4
PROTECTOR_SCAN_INTERVAL_SECONDS=30
PROTECTOR_DEEP_SCAN_INTERVAL_SECONDS=300

# ── Policy Engine ────────────────────────────────────────────────────────────
PROTECTOR_POLICY_PATH=./config/default_policy.yaml
PROTECTOR_POLICY_STRICT_MODE=true
PROTECTOR_AUTO_QUARANTINE_HIGH_RISK=true
PROTECTOR_RISK_THRESHOLD_WARN=0.4
PROTECTOR_RISK_THRESHOLD_BLOCK=0.7
PROTECTOR_RISK_THRESHOLD_QUARANTINE=0.85

# ── Audit / Integrity ────────────────────────────────────────────────────────
PROTECTOR_AUDIT_SIGNING_KEY_PATH=./protector_data/audit_key.pem
PROTECTOR_AUDIT_CHAIN_ENABLED=true

# ── Optional API Service ─────────────────────────────────────────────────────
PROTECTOR_API_ENABLED=false
PROTECTOR_API_HOST=127.0.0.1
PROTECTOR_API_PORT=8741

# ── Human Governance ─────────────────────────────────────────────────────────
PROTECTOR_REQUIRE_HUMAN_APPROVAL_ABOVE=0.7
PROTECTOR_ALERT_EMAIL=                 # optional, leave blank to disable
PROTECTOR_OPERATOR_ID=operator-1
